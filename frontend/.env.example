# ── BobaMaster Frontend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it is listed in .gitignore.

# WebSocket URL of the FastAPI backend (no trailing slash)
VITE_WS_URL=ws://localhost:8000

# REST API base URL of the FastAPI backend
VITE_API_URL=http://localhost:8000

# UUID of the shop to display on this terminal
VITE_SHOP_ID=00000000-0000-0000-0000-000000000001

# Display name shown in the top bar
VITE_STORE_NAME=Downtown Store
